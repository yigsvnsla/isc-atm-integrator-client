{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "outDir": "./dist",
        "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    }
    },
    "include": ["src/**/*"]
}
